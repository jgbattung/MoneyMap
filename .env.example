# =============================================================================
# Money Map — Environment Variables Example
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# For LOCAL development with Docker (docker-compose up -d):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/money_map_dev"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5433/money_map_dev"
#
# For PRODUCTION (Supabase):
# Use port 6543 (PgBouncer/Transaction mode) for DATABASE_URL
# Use port 5432 (Session mode / direct connection) for DIRECT_URL
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET="your-secret-here"
BETTER_AUTH_URL="http://localhost:3000"
